# PostgreSQL connection string. On Vercel this is provisioned automatically
# when you add a Neon database via Storage. For local dev you can either use
# the Neon URL or a local postgres instance (e.g. `docker run -d --name pg
# -e POSTGRES_PASSWORD=pg -p 5432:5432 postgres:16`).
DATABASE_URL="postgresql://postgres:pg@localhost:5432/postgres"

# Secret used to sign session cookies. Generate with:
#   openssl rand -base64 32
SESSION_SECRET="replace-me-with-a-long-random-string"
